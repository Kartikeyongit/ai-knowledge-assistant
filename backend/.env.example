DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_assistant
GROQ_API_KEY=
HF_API_TOKEN=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=llama-3.1-8b-instant
TITLE_MODEL=llama-3.1-8b-instant
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_DEMO_DOCS=5
UPLOAD_DIR=uploads
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
# Clerk JWT verification — set CLERK_JWKS_URL to your Clerk frontend API + /v1/jwks
# e.g. https://your-app.clerk.accounts.dev/v1/jwks
CLERK_JWKS_URL=
CLERK_JWT_AUTHORIZED_PARTY=
